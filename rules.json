{
  "extends": [
    "config:base",
    ":disableRateLimiting",
    ":semanticCommits",
    "group:allNonMajor"
  ],
  "timezone": "Asia/Tbilisi",
  "updateNotScheduled": false,
  "schedule": [
    "before 5am on Saturday"
  ],
  "packageRules": [
    {
      "matchDepNames": ["node"],
      "allowedVersions": "<=24"
    },
    {
      "matchDepNames": ["@ethberry/eslint-config"],
      "allowedVersions": "<6"
    },
    {
      "matchDepNames": ["@liaoliaots/nestjs-redis"],
      "allowedVersions": "<10"
    },
    {
      "updateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "automerge": false
    },
    {
      "updateTypes": [
        "major"
      ],
      "masterIssueApproval": true
    },
    {
      "matchPackageNames": ["@types/node"],
      "allowedVersions": "<=25"
    },
    {
      "matchPackageNames": ["cron"],
      "groupName": "@NestJS packages",
      "rangeStrategy": "replace",
      "enabled": false
    },
    {
      "matchPackagePrefixes": ["@framework/"],
      "enabled": false
    },
    {
      "matchPackagePrefixes": ["@ethberry/"],
      "commitMessageTopic": "EthBerry",
      "groupName": "@EthBerry packages",
      "groupSlug": "ethberry-packages",
      "rollbackPrs": false
    },
    {
      "matchPackagePrefixes": ["@mui/"],
      "commitMessageTopic": "MaterialUI",
      "groupName": "@MUI packages",
      "groupSlug": "mui-packages"
    },
    {
      "matchPackagePrefixes": ["@nestjs/"],
      "commitMessageTopic": "NestJS",
      "groupName": "@NestJS packages",
      "groupSlug": "nestjs-packages"
    },
    {
      "matchPackagePrefixes": ["@lexical/"],
      "matchPackageNames": ["lexical"],
      "commitMessageTopic": "Lexical",
      "groupName": "@Lexical packages",
      "groupSlug": "lexical"
    },
    {
      "matchPackagePrefixes": ["@storybook/"],
      "matchPackageNames": ["storybook"],
      "commitMessageTopic": "Storybook",
      "groupName": "@Storybook packages",
      "groupSlug": "storybook"
    }
  ],
  "major": {
    "masterIssueApproval": true
  },
  "dependencyDashboard": true,
  "npmrc": "@ethberry:registry=https://npm.pkg.github.com/",
  "npmrcMerge": true
}
